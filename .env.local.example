NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte key (64 hex chars) used to AES-256-GCM encrypt saved Meta tokens.
# Generate with: openssl rand -hex 32
METIS_TOKEN_ENCRYPTION_KEY=

# Existing admin gate (operator-only /admin/* observability area).
METIS_ADMIN_PASSWORD=
METIS_ADMIN_COOKIE_SECRET=
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-5.4-mini
META_REPORTING_ACCOUNT_ID=your-client-reporting-account-id
META_DRAFT_ACCOUNT_ID=your-draft-write-account-id
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
POC_OBSERVABILITY_LOG_PATH=logs/pocs/observability-runs.jsonl
POC_OPENROUTER_MIN_INTERVAL_MS=1500
POC_META_READ_MIN_INTERVAL_MS=1000
POC_META_WRITE_MIN_INTERVAL_MS=2000
POC_META_USAGE_WARNING_PCT=70
POC_META_USAGE_COOLDOWN_MS=15000
POC_SLACK_MIN_INTERVAL_MS=1000
